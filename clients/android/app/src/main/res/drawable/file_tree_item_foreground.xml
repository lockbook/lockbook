<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/file_tree_item_ripple_color">
    <!-- this configures the ripple size-->
    <item android:id="@android:id/mask">
        <inset
            android:insetLeft="@dimen/file_tree_item_container_horizontal_inset"
            android:insetTop="@dimen/file_tree_item_container_vertical_inset"
            android:insetRight="@dimen/file_tree_item_container_horizontal_inset"
            android:insetBottom="@dimen/file_tree_item_container_vertical_inset">
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/file_tree_item_container_radius" />
                <solid android:color="@android:color/white" />
            </shape>
        </inset>
    </item>
</ripple>
